<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="AccentBrush" Color="#6366F1" />
    <SolidColorBrush x:Key="CodexAccent" Color="#10B981" />
    <SolidColorBrush x:Key="ClaudeAccent" Color="#F97316" />
    <SolidColorBrush x:Key="CopilotAccent" Color="#6E40C9" />
    <SolidColorBrush x:Key="CursorAccent" Color="#64748B" />
    <SolidColorBrush x:Key="SessionAccent" Color="#F59E0B" />
    <SolidColorBrush x:Key="WeeklyAccent" Color="#8B5CF6" />

    <!-- Dims a usage panel when the provider login needs re-auth (stale numbers). -->
    <Style x:Key="SignInDimmedPanel" TargetType="StackPanel">
        <Style.Triggers>
            <DataTrigger Binding="{Binding NeedsSignIn}" Value="True">
                <Setter Property="Opacity" Value="0.4" />
            </DataTrigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
